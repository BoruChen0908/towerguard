OPENSKY_CLIENT_ID=your_client_id_here
OPENSKY_CLIENT_SECRET=your_client_secret_here
REDIS_URL=redis://localhost:6379/0

# --- LLM augmentation (optional) -------------------------------------------
# The Live Validation half can use Claude to phrase the advisory text and the
# relief briefing. It is OFF by default and degrades to the deterministic
# template when unset or on any API error, so the demo runs fully offline.
# Set BOTH to turn it on:
TOWERGUARD_USE_LLM=0
ANTHROPIC_API_KEY=
# Optional model override (defaults to claude-opus-4-8):
# TOWERGUARD_LLM_MODEL=claude-opus-4-8
